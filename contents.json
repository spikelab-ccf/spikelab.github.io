    "about":  {
                  "title":  "About",
                  "body":  "**SPIKE Lab** (*Signal Processing for Intelligent Knowledge of Epilepsy*) is a translational research laboratory dedicated to improving the lives of patients with neurological disorders, with a primary focus on epilepsy.\n\nWe develop clinically grounded signal processing and computational methods to extract meaningful insights from non-invasive recordings (scalp EEG, MEG) and invasive recordings (intracranial EEG/SEEG). By emphasizing interpretability, robustness, and clinical relevance, we aim to advance the understanding, diagnosis, and treatment of epilepsy, especially in patients with challenging, non-lesional, and drug-resistant disease.\n\nOur work is rooted in the belief that effective algorithms must be physiologically informed and clinically interpretable to support real-world decision-making. At the intersection of neuroscience, engineering, and clinical care, we translate advanced signal analysis into actionable biomarkers, network-level insights, and tools for diagnosis, localization, and personalized treatment."
              },
    "research":  {
                     "title":  "Research",
                     "items":  [
                                   {
                                       "name":  "AI and Patient-Specific Models",
                                       "description":  "We develop machine learning and AI methods, built on robust signal processing pipelines, to support surgical planning, predict seizure risk, and tailor interventions to individual patients. By integrating large-scale EEG, MEG, and stereo-EEG datasets, our approaches provide interpretable, patient-specific guidance for clinicians.",
                                       "image":  "assets/sections/research/AI and Patient-Specific Models.png",
                                       "alt":  "AI and Patient-Specific Models"
                                   },
                                   {
                                       "name":  "Brain Connectivity and Biomarker Discovery",
                                       "description":  "Using advanced signal processing and network analysis, we map functional and directional brain connectivity, identify critical nodes within epileptic networks, and discover electrophysiological biomarkers. These insights help understand seizure propagation, improve localization, and guide diagnosis and treatment - including in non-lesional epilepsy.",
                                       "image":  "assets/sections/research/Brain Connectivity and Biomarker Discovery.png",
                                       "alt":  "Brain Connectivity and Biomarker Discovery"
                                   },
                                   {
                                       "name":  "Translational Tools and Multimodal Integration",
                                       "description":  "We translate our algorithms into practical, clinician-ready tools and combine EEG, MEG, and MRI data to create a holistic view of brain function and pathology. By bridging non-invasive and invasive recordings, we enhance diagnostic accuracy, surgical planning, and personalized treatment strategies.",
                                       "image":  "assets/sections/research/Translational Tools and Multimodal Integration.png",
                                       "alt":  "Translational Tools and Multimodal Integration"
                                   }
                               ]
                 },
